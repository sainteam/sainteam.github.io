              "background-image": "url(@bg-value)"
            },
            ".mbr-section-subtitle": {
              "color": "#b71010",
              "font-weight": "300"
            },
            ".mbr-content-text": {
              "color": "#767676",
              "margin-bottom": "0"
            },
            ".card": {
              "word-wrap": "break-word",
              "flex-shrink": "0",
              "-webkit-flex-shrink": "0"
            },
            ".mbr-iconfont when (@showIcons)": {
              "font-size": "80px",
              "color": "#149dcc"
            },
            ".cards-block when (@showBorders)": {
              "@media (min-width: 992px)": {
                "border-top": "2px solid @bordersColor"
              },
              ".card": {
                "border-bottom": "2px solid @bordersColor",
                "border-radius": "0"
              }
            },
            ".cards-container": {
              "display": "flex",
              "-webkit-flex-direction": "row",
              "flex-direction": "row",
              "-webkit-flex-wrap": "wrap",
              "flex-wrap": "wrap",
              "-webkit-justify-content": "center",
              "justify-content": "center",
              "word-break": "break-word"
            },
            ".media-block when (@showMedia)": {
              "flex-shrink": "0",
              "-webkit-flex-shrink": "0",
              "@media (min-width: 992px)": {
                "& when (@reverseContent)": {
                  "padding-left": "2rem"
                },
                "& when not (@reverseContent)": {
                  "padding-right": "2rem"
                }
              }
            },
            ".cards-block": {
              "flex-basis": "100%",
              "-webkit-flex-basis": "100%"
            },
            "@media (max-width: 991px)": {
              ".media-block": {
                "flex-basis": "100%",
                "-webkit-flex-basis": "100%",
                "padding-left": "0",
                "padding-bottom": "2rem"
              }
            },
            "@media (min-width: 768px)": {
              ".count": {
                "width": "100px"
              }
            },
            "@media (max-width: 767px)": {
              ".panel-item": {
                "-webkit-flex-wrap": "wrap",
                "flex-wrap": "wrap"
              },
              ".card-img when (@showTitles), (@showText)": {
                "padding-bottom": "1rem",
                "padding-right": "0 !important",
                "margin": "auto"
              }
            },
            ".media-container-row when (@reverseContent) and (@showMedia)": {
              "-webkit-flex-direction": "row-reverse",
              "flex-direction": "row-reverse"
            },
            ".mbr-section-title": {
              "color": "#b71010"
            },
            ".count": {
              "color": "#b71010"
            },
            "H4": {
              "color": "#b71010"
            }
          },
          "_name": "counters3",
          "_customHTML": "<section class=\"counters3 counters\" group=\"Counters\" plugins=\"ViewportChecker\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Сверху\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Снизу\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"6\">\n        <input type=\"checkbox\" title=\"Название\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Подзаголовок\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Иконки\" name=\"showIcons\" checked>\n        <input type=\"checkbox\" title=\"Заголовок\" name=\"showTitles\" checked>\n        <input type=\"checkbox\" title=\"Текст\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Иконки\" name=\"showIcons\">\n        <input type=\"checkbox\" title=\"Медиа\" name=\"showMedia\" checked>\n        <input type=\"range\" title=\"Размер медиа\" inline name=\"mediaSize\" min=\"20\" max=\"60\" value=\"45\" condition=\"showMedia\">\n        <input type=\"checkbox\" title=\"Медиа Слева/Справа\" name=\"reverseContent\" condition=\"showMedia\" checked>\n        <select title=\"Число карт\" name=\"cardsAmount\">\n           <option value=\"1\" selected>1</option>\n           <option value=\"2\">2</option>\n           <option value=\"3\">3</option>\n           <option value=\"4\">4</option>\n        </select>\n        <input type=\"checkbox\" title=\"Show Borders\" name=\"showBorders\" checked>\n        <input type=\"color\" title=\"Border Color\" name=\"bordersColor\" value=\"#b71010\" condition=\"showBorders\">\n        <fieldset type=\"background\" name=\"bg\" parallax>\n           <input type=\"image\" title=\"Фоновое изображение\" value=\"../_images/background2.jpg\">\n           <input type=\"color\" title=\"Цвет фона\" value=\"#ffffff\" selected>\n           <input type=\"video\" title=\"Фоновое видео\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Наложение\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Цвет наложения\" name=\"overlayColor\" value=\"#cccccc\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Прозрачность\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container pt-4 mt-2\">\n        <h2 class=\"mbr-section-title pb-3 align-center mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">Сервера</h2>\n        <h3 class=\"mbr-section-subtitle pb-5 align-center mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n            1917RP | S A I N T E A M project</h3>\n        <div mbr-class=\"{'media-container-row': showMedia,\n                         'row justify-content-center': !showTitle && !showSubtitle && !showMedia}\">\n            <div class=\"media-block m-auto\" mbr-style=\"{'width': mediaSize + '%'}\" mbr-if=\"showMedia\">\n                <div class=\"mbr-figure\">\n                    <img src=\"@PROJECT_PATH@/assets/images/1917rp-1024x640.png\" alt title>\n                </div>\n            </div>\n            <div class=\"cards-block\">\n                <div class=\"cards-container\">\n                    <div class=\"card px-3 align-left col-12\">\n                        <div class=\"panel-item p-4 d-flex align-items-center\">\n                            <div class=\"card-img pr-3 d-flex align-items-center align-left\">\n                                <span mbr-icon mbr-if=\"showIcons\" class=\"mbri-mobirise mbr-iconfont pr-2\"></span>\n                                <h3 class=\"count py-3 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".count\">1917</h3>\n                            </div>\n                            <div class=\"card-text\">\n                                <h4 class=\"mbr-content-title mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitles\"><span style=\"font-weight: normal;\">\n                                    1917RP | S A I N T E A M project</span></h4>\n                                <p class=\"mbr-content-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-content-text\">Игра: <a href=\"https://store.steampowered.com/app/4000/Garrys_Mod/\" target=\"_blank\" class=\"text-info\"><b>Garry's Mod</b></a><br>IP: ?<br>Статус сервера: В поиске хоста<br>Режим сервера: <a href=\"https://steamcommunity.com/sharedfiles/filedetails/?id=248302805&searchtext=darkrp\" target=\"_blank\" class=\"text-info\"><b>DarkRP</b></a><br>Контент сервера: <a href=\"https://steamcommunity.com/sharedfiles/filedetails/?id=1494763402\" target=\"_blank\" class=\"text-info\"><b>1917RP Content</b></a><br>Группа Проекта: <a href=\"http://vk.com/sainteamgroup\" target=\"_blank\" class=\"text-info\"><b>vk.com/sainteamgroup</b></a><br>Cоздатель сервера: <a href=\"https://steamcommunity.com/id/Mr_Prorok_/\" target=\"_blank\" class=\"text-info\"><b>The Saint Prophet</b></a> (<a href=\"http://vk.com/prorokvlad\" target=\"_blank\" class=\"text-info\"><b>Владислав Профет</b></a>)</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card px-3 align-left col-12\" mbr-if=\"cardsAmount>1\">\n                        <div class=\"panel-item p-4 d-flex align-items-center\">\n                            <div class=\"card-img pr-3 d-flex align-items-center align-left\">\n                                <span mbr-icon mbr-if=\"showIcons\" class=\"mbri-extension mbr-iconfont pr-2\"></span>\n                                <h3 class=\"count py-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" data-app-selector=\".count\">\n                                    200\n                                </h3>\n                            </div>\n                            <div class=\"card-text\">\n                                <h4 class=\"mbr-content-title mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitles\">\n                                    Трендовые блоки\n                                </h4>\n                                <p class=\"mbr-content-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-content-text\">\n                                    Большой выбор готовых блоков.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card px-3 align-left col-12\" mbr-if=\"cardsAmount>2\">\n                        <div class=\"panel-item p-4 d-flex align-items-center\">\n                            <div class=\"card-img pr-3 d-flex align-items-center align-left\">\n                                <span mbr-icon mbr-if=\"showIcons\" class=\"mbri-responsive mbr-iconfont pr-2\"></span>\n                                <h3 class=\"count py-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" data-app-selector=\".count\">\n                                    300\n                                </h3>\n                            </div>\n                            <div class=\"card-text\">\n                                <h4 class=\"mbr-content-title mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitles\">\n                                    Bootstrap\n                                </h4>\n                                <p class=\"mbr-content-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-content-text\">\n                                        Bootstrap  - это лучшая отзывчивость \n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card px-3 align-left col-12\" mbr-if=\"cardsAmount>3\">\n                        <div class=\"panel-item p-4 d-flex align-items-center\">\n                            <div class=\"card-img pr-3 d-flex align-items-center align-left\">\n                                <span mbr-icon mbr-if=\"showIcons\" class=\"mbri-globe-2 mbr-iconfont pr-2\"></span>\n                                <h3 class=\"count py-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" data-app-selector=\".count\">\n                                    400\n                                </h3>\n                            </div>\n                            <div class=\"card-texts\">\n                                <h4 class=\"mbr-content-title mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitles\">\n                                    Веб-шрифты\n                                </h4>\n                                <p class=\"mbr-content-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-content-text\">\n                                        Mobirise легко и просто подключает на ваш сайт шрифты Google.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "rqU7fHnX5o",
          "_anchor": "counters3-b",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            ".mbr-section-subtitle": {
              "color": "#ffffff"
            },
            "H2": {
              "color": "#ffffff"
            },
            ".mbr-section-subtitle DIV": {
              "text-align": "left"
            }
          },
          "_name": "content4",
          "_customHTML": "<section class=\"mbr-section content4\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Сверху\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Снизу\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n\n        <input type=\"checkbox\" title=\"Название\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Подзаголовок\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Кнопки\" name=\"showButtons\">\n        <input type=\"color\" title=\"Цвет фона\" name=\"bgColor\" value=\"#b71010\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"title col-12 col-md-8\">\n                <h2 mbr-if=\"showTitle\" class=\"align-center pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\">Правила</h2>\n                <h3 mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" class=\"mbr-section-subtitle align-center mbr-light mbr-fonts-style\" mbr-theme-style=\"display-7\">Правила DarkRP режима (стандартные)<br><div><br></div><br><br><div>&nbsp; &nbsp;I. Основные правила за нарушение которых можно получить бан.</div><div>1.1. RDM (Random Death Match)</div><div>Запрещается убийство одного человека или нескольких людей без видимой на то причины любыми способами. Любое действие которое как-нибудь попадает под нарушение данного правила - карается. Стоит обратить внимание, что никто (даже Хелпер-Администратор) не имеет права на убийство других игроков без причины в любой ситуации. Данное правило касается абсолютно все профессии и классы.</div><div><br></div><div>1.2. NLR (New Life Rule)</div><div>При смерти в связи с любой причиной (убийство, самоубийство, голод и т.д.) вы забываете убийцу, обстоятельства убийства и место смерти. Запрещено возвращаться на место смерти в течении 5 минут после неё, даже если это ваш дом/квартира/жилище/база/хранилище/сарай. Нельзя мстить человеку, убившему вас. Если вы считаете, что он убил вас без видимых на то причин, то соберите доказательства против него и позовите админа.</div><div><br></div><div>1.3. NonRP</div><div>Данное правило состоит в сопоставлении смысла и мотивов игровых событий событиям в реальной жизни. Пример нарушения: держать в руках любое оружие в общественных местах (улицы города, бары, магазины, торговые центы и т.д.), совершение криминальных действий за вполне мирные профессии (повар, вор или гражданин с миниганом), попытаться украсть что-то у кого-то на глазах жителей города и т.д. Далее будут описываться тонкости игры за каждую из существующих на сервере профессий (но никакое правило отображенное там не нарушает и не изменяет данное правило). Так же вы не имеете право покупать более 2 домов.</div><div><br></div><div>1.4. FearRP</div><div>Любой игрок сервера должен боятся того, чего боятся люди в реальной жизни. Нельзя спрыгивать с крыш высоких зданий, нельзя убегать от вооруженного человека под дулом ружья, нельзя оскорблять или как-то издеваться над группой полицейских. Ваш верный помощник не совершать данные действия в реальной жизни - чувство самосохранения, так как данного чувства в DarkRP пока что нет, то вам придется сопоставлять игровые события именно с этим важным чувством в реальной жизни.</div><div><br></div><div>1.5. Prop Surf, Prop Climb</div><div>Попытка превратить проп в летательный аппарат и взлет на нем с помощью физгана (Physgun) в окна/форточки/крыши зданий/широко распахнутые двери запрещается! Постройка на скорую руку лестниц из различных пропов (решетки, шкафы, лампы и т.д.) так же запрещены.</div><div><br></div><div>1.6. Prop Push, Prop Kill, Prop Flood/Prop Spam</div><div>Нельзя использовать пропы для того чтобы толкнуть/убить/пододвинуть кого то или что то. Запрещается рандомный сверхскоростной, а так же частый спавн любых пропов.</div><div><br></div><div>1.7. Prop Block</div><div>Запрещается закрывать какие-либо проходы, либо местность с помощью пропов для того, чтобы люди не смогли попасть в определенную точку карты.  Запрещается менять материал пропов на невидимый (либо материал с белыми линиями). Нельзя закрывать какой-либо проход без использования связки Fading Door + Keypad. Запрещается закрывать кейпад какими-либо пропами (даже с FD), а так же запрещается ставить кейпады на удалении от Fading Door который он открывает. Запрещается ставить невидимые кнопки. Запрещается закрывать без Fading Door какой либо проход/дверь. Все двери в доме/гараже/сарае должны быть с Fading Doors и Кейпадами (не забываем про правило 1 Проход/Дверь - 1 FD - 2 Кейпада). Запрещается делать Fading Door близко друг к другу (если они не ставятся на РП двери конечно). Запрещается строить дома что-то что как-либо напоминает туннель/коридор/змейку/лабиринт. Разрешается блокировать окна в доме (пропом с ФД (Fading Door) без кейпада).</div><div><br></div><div>1.8. Door/Fading Door abuse</div><div>Запрещается использовать инструменты (тулы) Fading Door + Keypad (без параметра Toggle), если параметр Hold Length в настройках кейпада настроен на время менее 6 секунд, что означает закрытие дверей раньше чем пройдет 6 секунд. Запрещается использовать инструмент Fading Door для динамичных перестрелок. Пример одной из таких перестрелок: Нагибатор228 поставил Fading Door и кейпады и решил использовать его в перестрелках, он целится во врага, открывает Fading Door на пару секунд, убивает недоброжелателя выстрелом в голову и закрывает Fading Door.</div><div>• Запрещается мешать взламывать вашу дверь ворам/другим преступным личностям посредством открытия и закрытия Fading Door'а. Запрещается ставить на проход/дверь более 1 Fading door. Запрещается закрывать какие либо двери/проходы без Fading door. Если есть проход (дверь) то он должен быть либо открыт, либо на нем должен стоять один Fading door. Разрешается ставить в доме Fading door только на большом расстоянии от других Fading door. Так же нельзя прятать маники в пропы с помощью Fading doors (вне зависимости есть кейпад/кнопка или нет).</div><div><br></div><div>1.9. Job Abuse</div><div>Запрещается смена профессий в течении короткого промежутка времени для получения из этого выгоды. нельзя менять свою профессию к примеру с гангстера на вора и взламывать закрытую дверь другого игрока, нельзя менять свою профессию у себя дома для того чтобы совершить какое-либо действие которое доступно только этой профессии (например смена профессии в логове банды с грабителя на повара и покупка микроволновки для того чтобы накормить себя и своих друзей).</div><div><br></div><div>1.10. RDM Arrest</div><div>Если вы играете за представителя правоохранительных органов, то вам стоит знать, что арест людей без причины в любых обстоятельствах запрещается.</div><div>Весомая причина для ареста: Человек разгуливает среди бела дня по площади и носит оружие в руках и даже направляет его на людей. Даже наличие лицензии не разрешает этого делать.</div><div>Плохая причина: Сотрудник Полиции подходит к человеку, обыскивает его, находит у него оружие и моментально сажает человека в тюрьму.</div><div>Примечание: Зачастую во время Ком Часа в некоторых сотрудниках правопорядка просыпаются мастера красной палки (палки ареста) и они начинают ей размахивать направо и налево объясняя это тем что сейчас идет Ком Час, однако многие из них не знают (или притворяются что не знают) что сначала нужно сделать предупреждение, и только после этого, если человек не слушает его, сотрудник правопорядка имеет право посадить человека в тюрьму.</div><div><br></div><div>1.11. RDM Demote или Demote Abuse</div><div>Увольнение какой либо персоны с наличием некорректной причины или вообще с отсутствием причины. Перед тем как жать на кнопку \"Уволить игрока\" вам стоит задуматься о том, что же вы будете рассказывать админам если они спросят причину демоута, так что вам стоит подготовить развернутый ответ подкрепленный различными доказательствами - почему данная персона не соответствует своей профессии и заслуживает увольнения. Запрещается увольнять какого-либо игрока по причине лимита слотов на определенную профессию, если объяснять по простому языку - нельзя увольнять человека если вы хотите занять его профессию, но не можете сделать этого из-за лимита.</div><div>Правильные причины увольнения: RDM, RDM Arrest, Job Abuse и тому подобные причины.</div><div>Неправильные причины увольнения: \"Он полный лах!\", \"Вабще ни работаит! Все ДА!\" и т.д.</div><div><br></div><div>1.12. RDM Warrant</div><div>Запрещается проводить обыск какого либо жилища по причине \"Maniki\", \"Обыск\", \"111\" и т.д. Для того чтобы запросить ордер вы должны иметь неоспоримые доказательства в виде фактов, а не простых догадок. Нельзя просто так подбежать к человеку и тут же обыскать его на наличие нелегального оружия.&nbsp;</div><div>Пояснение: Если вам говорят \"ЕЙ! СМОТРИ, ИСКРЫ ИЗ СТЕНЫ! ТАМ МАНИКИ! ПЛИЗЗ ОБЫЩИ ДОМ!!1 БЫСТРЕЕ!11\" и вы уже направились запрашивать ордер на обыск, то спешу огорчить вас огорчить и сообщить что искры из стены здания причиной для обыска не является, так же как и звук Мани Принтеров (во всем этом виноват только движок игры и причиной для обыска это являться никак не может). Корректной причиной для проведения обыска может являться только грамотная просьба, а еще лучше свидетельство большого количества людей, или то нарушение, которое вы увидели сами. Например - в дом заносят ящики с оружием/маники и вы/свидетели все это видят. Только в таких случаях вы имеете право провести обыск, все иные случаи описанные выше караются баном.</div><div><br></div><div>1.13. Custom Job</div><div>Запрещается использование команды /job для изменения собственной профессии на название других профессий, а так же выдуманных слов/статусов/имен/фамилий/титулов (Введенная игроком \"профессия\" - \"Васян1337\" не является РП профессией).</div><div>Разрешается</div><div>• использование команды /job для изменения собственной профессии на слово синоним этой же профессии.</div><div><br></div><div>1.14. Advert Abuse</div><div>Запрещается реклама которая начинает распространяться большими буквами и развешана по всему городу, так реклама перерастает попросту в спам. Запрещается без согласия хозяина вешать рекламу на дома чужих людей. Если вы все же сделали это, а владелец дома просит вас удалить рекламу - лучше не быть плохим парнем и удалить свою рекламу на чужом доме, потому что обычно такие плохие парни улетают в бан.</div><div><br></div><div>1.15. Мат/Оскорбления</div><div>Если вы хотите материться и посылать всех в ООС, то поспешу вас огорчить, наш сервер не поощряет различные лингвистические вольности ( если это не касается RP ). Если вы хотите кого то оскорбить - выключайте микрофон и орите сколько захотите, но если вы собираетесь разговаривать на нашем сервере, то таких случаев оскорблений/мата быть не должно.</div><br><br><div><br></div><div>&nbsp; &nbsp;II. Правила хорошего Roleplay.</div><div>2.1. Если не хотите жить на улице – купите себе квартиру или дом за городом. Чаще всего иметь в собственности какое-либо жилище просто жизненно необходимо (особенно ворам где они будут складывать все что наворовали). Так же вам необходимо будет научится хорошо расставить мебель и создать прекрасную атмосферу уюта, даже в гангстерском притоне.</div><div><br></div><div>2.2. Почти что первое правило правильного РП – старайтесь ходить с пустыми руками т.к. в реальной жизни нет тулганов, физганов и гравиганов, а так же хождение с оружием по городу без видимых причин будет являться арестом.</div><div><br></div><div>2.3. Не нарывайтесь на неприятности. Т.к. правило FearRP никто не отменял – вы должны вести себя в обществе всегда вежливо.</div><div><br></div><div>2.4. Не поддавайтесь на провокации нарушителей и продолжайте отыгрывать роль. Вы должны быть максимально адекватны в таких ситуациях.</div><div><br></div><div>2.5. Помните, что пропы это одна из важных составляющих в мире DarkRP. Если вы решили заспавнить дома кучу пропов миниганов – будьте готовы к аресту т.к. оружие оно и есть оружие, вне зависимости проп это или нет.</div><br><br><div><br></div><div>&nbsp; &nbsp;III. Законы города и правила правоохранительных органов.</div><div>Законы города, которые не может менять мэр</div><div><br></div><div>3.1. Убийства граждан города, вне зависимости было ли убийство умышленным или нет – запрещены( при условии что улик не было найдено ).</div><div><br></div><div>3.2. Нанесение увечий жителям города или каких-либо повреждений их собственности наказуемо.</div><div><br></div><div>3.3. Запрещается иметь при себе оружие без соответствующей лицензии на ношение оружия.</div><div><br></div><div>3.4. Запрещается использовать или носить оружие наготове в открытых местах, даже если у вас есть лицензия (не считая сотрудников правопорядка).</div><div><br></div><div>3.5. Варка/производство/изготовление наркотических веществ и всех производных этих веществ запрещены.</div><div><br></div><div>3.6. Сопротивление сотрудникам правоохранительных органов и невыполнение их требований является нарушением закона.</div><div><br></div><div>3.7. Денежные принтеры запрещены. Они вызывают такие неприятные ситуации как подрыв экономики города и инфляция.</div><div><br></div><div>3.8. Запрещается вандализм и порча имущества.</div></h3>\n                <div class=\"mbr-section-btn align-center py-4\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a class=\"btn btn-primary\" href=\"https://mobirise.co\">ПОДРОБНЕЕ</a>\n                    <a class=\"btn btn-black-outline\" href=\"https://mobirise.co\">ДЕМО</a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "rqQKB24Sbp",
